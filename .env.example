# Copy this file to .env.local and replace every placeholder with your own values.
# Never commit .env.local or real secrets.

# App URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase - choose either your remote project values or local values from `pnpm exec supabase status`.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# LLM Gateway
LLM_GATEWAY_API_KEY=""

# Stripe - use each student's own Stripe test workspace values.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_ALLOWED_PRICE_IDS=""
# Optional: set these when you create monthly/yearly prices so webhook plan detection is deterministic.
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# Comma-separated origins allowed as Stripe Checkout / Customer Portal return destinations.
ALLOWED_REDIRECT_ORIGINS="http://localhost:3000"
