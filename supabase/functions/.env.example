# Copy this file to supabase/functions/.env for local Supabase Edge Functions.
# For remote Supabase Edge Functions, set the same values with `pnpm exec supabase secrets set`.
# Never commit supabase/functions/.env or real secrets.

# Supabase automatically provides SUPABASE_URL and service/publishable keys to Edge Functions.
# Only app/third-party settings are listed here.

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
LLM_GATEWAY_API_KEY=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_ALLOWED_PRICE_IDS=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
ALLOWED_REDIRECT_ORIGINS="http://localhost:3000"
